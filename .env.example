# Environment Configuration for Structural Analysis Pipeline API

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO

# Model Paths
MODEL_PATH_STAGE2=models/stage2_model.pth
MODEL_PATH_STAGE3=models/column_predictor_no_leakage.pth

# Data Directories
TEMP_DATA_DIR=temp_data
UPLOAD_DIR=temp_data/uploads
RESULTS_DIR=temp_data/results

# File Management
MAX_FILE_AGE_HOURS=24
MAX_UPLOAD_SIZE_MB=100

# Performance Settings
BATCH_SIZE=32
MAX_CONCURRENT_JOBS=10

# GPU Settings (optional)
CUDA_VISIBLE_DEVICES=0
USE_GPU=true

# Monitoring (optional)
ENABLE_METRICS=false
METRICS_PORT=9090

# Security (optional)
API_KEY_REQUIRED=false
API_KEY=your-secret-api-key-here

# Database (optional - for job persistence)
DATABASE_URL=sqlite:///jobs.db

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379/0